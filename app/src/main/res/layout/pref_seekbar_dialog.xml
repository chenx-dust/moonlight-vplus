<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="8dp"
    android:paddingBottom="4dp">

    <!-- 说明文本 -->
    <TextView
        android:id="@+id/pref_seekbar_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="#666666"
        android:paddingBottom="12dp"
        android:visibility="gone" />

    <!-- 数值显示区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="16dp">

        <!-- 减小按钮 -->
        <ImageView
            android:id="@+id/pref_seekbar_btn_minus"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/pref_adjust_btn_bg"
            android:scaleType="center"
            android:contentDescription="减小"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true" />

        <!-- 数值容器 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/pref_value_bg"
                android:gravity="center">

                <TextView
                    android:id="@+id/pref_seekbar_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textColor="@color/theme_pink_primary"
                    android:textStyle="bold"
                    android:text="0"
                    android:minWidth="60dp"
                    android:gravity="center" />

            </LinearLayout>

        </LinearLayout>

        <!-- 增大按钮 -->
        <ImageView
            android:id="@+id/pref_seekbar_btn_plus"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/pref_adjust_btn_bg"
            android:scaleType="center"
            android:contentDescription="增大"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- SeekBar -->
    <SeekBar
        android:id="@+id/pref_seekbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:progressDrawable="@drawable/pref_seekbar_track"
        android:thumb="@drawable/pref_seekbar_thumb"
        android:splitTrack="false"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:focusable="true"
        android:focusableInTouchMode="true" />

    <!-- 范围标签 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="4dp">

        <TextView
            android:id="@+id/pref_seekbar_min_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#999999" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/pref_seekbar_max_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#999999" />

    </LinearLayout>

</LinearLayout>
