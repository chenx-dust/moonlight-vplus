<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/advance_setting_background"
    android:clipChildren="false"
    android:clipToPadding="false"
    tools:context=".AppView">

    <!-- 背景图 -->
    <ImageView
        android:id="@+id/appBackgroundImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.33" />

    <!-- App 图标网格容器 -->
    <FrameLayout
        android:id="@+id/appFragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true" />

    <!-- 选中框动画 -->
    <View
        android:id="@+id/selectionIndicator"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/selection_indicator"
        android:visibility="invisible"
        android:elevation="8dp"
        android:clipChildren="false"
        android:clipToPadding="false" />

    <!-- 顶部下拉手柄标签 -->
    <TextView
        android:id="@+id/topPanelToggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_alignParentTop="true"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="4dp"
        android:paddingBottom="6dp"
        android:text="\u2699 \u25BE"
        android:textColor="#B3FFFFFF"
        android:textSize="13sp"
        android:fontFamily="sans-serif-light"
        android:background="@drawable/dropdown_handle_background"
        android:clickable="true"
        android:focusable="true"
        android:focusableInTouchMode="false" />

    <!-- 顶部下拉面板 -->
    <LinearLayout
        android:id="@+id/topDropdownPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/topPanelToggle"
        android:layout_centerHorizontal="true"
        android:minWidth="200dp"
        android:orientation="vertical"
        android:background="@drawable/dropdown_panel_background"
        android:padding="@dimen/appview_panel_padding"
        android:elevation="@dimen/appview_panel_elevation"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:descendantFocusability="afterDescendants"
        android:visibility="gone">

        <!-- 设置入口 -->
        <TextView
            android:id="@+id/settingsEntry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_settings"
            android:textColor="@color/appview_text_primary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-light"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:paddingStart="4dp"
            android:paddingEnd="16dp"
            android:background="?android:attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true" />

        <!-- 显示器选择区域 -->
        <LinearLayout
            android:id="@+id/displaySelectionInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="start"
            android:layout_marginTop="4dp"
            android:visibility="gone">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33FFFFFF"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/appview_display_selection_title"
                android:textColor="@color/appview_text_secondary"
                android:textSize="11sp"
                android:fontFamily="sans-serif-light"
                android:paddingStart="4dp"
                android:paddingBottom="4dp" />

            <RadioGroup
                android:id="@+id/displayRadioGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="start"
                android:layout_gravity="start" />

            <TextView
                android:id="@+id/screenCombinationModeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/appview_text_secondary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-light"
                android:paddingTop="4dp"
                android:paddingBottom="2dp"
                android:paddingStart="4dp"
                android:paddingEnd="@dimen/appview_edge_margin"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

    <!-- 标题区域（电脑名 + 应用名 + 恢复箭头） -->
    <TextView
        android:id="@+id/appListText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_below="@id/topPanelToggle"
        android:layout_marginTop="4dp"
        android:layout_marginStart="@dimen/appview_content_margin"
        android:layout_marginEnd="@dimen/appview_content_margin"
        android:gravity="end"
        android:paddingBottom="@dimen/appview_content_padding"
        android:preferKeepClear="true"
        android:textSize="24sp"
        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="14sp"
        android:autoSizeMaxTextSize="28sp"
        android:autoSizeStepGranularity="1sp"
        android:textStyle="normal"
        android:fontFamily="sans-serif-light"
        android:textColor="@color/appview_text_primary"
        android:shadowColor="@color/appview_text_shadow"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="4"
        android:maxLines="3"
        android:ellipsize="end"
        android:lineSpacingExtra="4dp"
        android:breakStrategy="balanced"
        android:hyphenationFrequency="normal"
        android:clickable="true"
        android:focusable="true"
        android:background="?android:attr/selectableItemBackground" />

    <!-- 底部信息容器 -->
    <LinearLayout
        android:id="@+id/bottomInfoContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="@dimen/appview_content_margin"
        android:layout_marginEnd="@dimen/appview_content_margin"
        android:layout_marginBottom="@dimen/appview_bottom_margin"
        android:orientation="vertical"
        android:gravity="end">

        <!-- 上一次设置信息 -->
        <LinearLayout
            android:id="@+id/lastSettingsInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end"
            android:visibility="gone">

            <CheckBox
                android:id="@+id/useLastSettingsCheckbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:focusable="true"
                android:text="@string/app_last_settings_use_checkbox"
                android:textColor="@color/appview_text_secondary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-light"
                android:buttonTint="@color/appview_text_primary"
                android:checked="false" />

            <TextView
                android:id="@+id/lastSettingsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/appview_text_secondary"
                android:shadowColor="@color/appview_text_shadow"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:fontFamily="sans-serif-light"
                android:background="@drawable/settings_info_background"
                android:padding="@dimen/appview_edge_margin"
                android:maxLines="3"
                android:ellipsize="end"
                android:lineSpacingExtra="2dp"
                android:text="@string/app_last_settings_title" />

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>